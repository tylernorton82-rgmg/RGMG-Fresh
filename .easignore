# EAS Build Ignore File
# Prevents permission errors and bloat during cloud builds

# Expo generated directories (CRITICAL - causes tar permission errors)
.expo
.expo/
.expo/*
.expo-shared
.expo-shared/

# Dependencies (reinstalled on build server)
node_modules
node_modules/
node_modules/*

# Native directories (managed workflow regenerates these)
android
android/
android/*
ios
ios/
ios/*

# Build outputs
dist
dist/
build
build/
web-build
web-build/

# Logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories
.idea
.vscode
*.swp
*.swo
*~

# Test coverage
coverage
coverage/

# TypeScript cache
*.tsbuildinfo

# Metro bundler cache
.metro-health-check*
